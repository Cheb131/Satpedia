  m_Name: KischNghijch
  m_EditorClassIdentifier: 
  skillName: "K\xEDch Ngh\u1ECBch"
  skillDescription: "Sau khi b\u1EA1n nh\u1EADn s\xE1t th\u01B0\u01A1ng, b\u1EA1n
    c\xF3 th\u1EC3 tr\u1ECDng ch\xFA (\u0111\u1ED5i b\xE0i) t\xF9y \xFD b\xE0i tr\xEAn
    tay (s\u1ED1 l\u01B0\u1EE3ng b\xE0i tr\u1ECDng ch\xFA b\u1EB1ng c\xE1ch n\xE0y
    m\u1ED7i l\u01B0\u1EE3t kh\xF4ng th\u1EC3 v\u01B0\u1EE3t qu\xE1 gi\u1EDBi h\u1EA1n
    sinh l\u1EF1c c\u1EE7a b\u1EA1n). N\u1EBFu b\u1EA1n b\u1EB1ng c\xE1ch n\xE0y
    thu \u0111\u01B0\u1EE3c [S\xE1t], b\u1EA1n c\xF3 th\u1EC3 s\u1EED d\u1EE5ng m\u1ED9t
    l\xE1 [S\xE1t] kh\xF4ng h\u1EA1n ch\u1EBF c\u1EF1 ly \u0111\u1ED3ng th\u1EDDi
    kh\xF4ng th\u1EC3 b\u1ECB h\u01B0\u1EDFng \u1EE9ng \u0111\u1ED1i v\u1EDBi ngu\u1ED3n
    s\xE1t th\u01B0\u01A1ng.\r\n"
  urlVoice: []
